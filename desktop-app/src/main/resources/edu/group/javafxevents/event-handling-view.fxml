<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.group.javafxevents.EventHandlingController"
            prefHeight="680.0"
            prefWidth="880.0">
    <top>
        <VBox spacing="14.0" styleClass="header-panel">
            <padding>
                <Insets bottom="18.0" left="24.0" right="24.0" top="16.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="mode-navigation">
                <VBox spacing="2.0">
                    <Label styleClass="path-label" text="CHOOSE YOUR PATH" />
                    <Label styleClass="path-copy" text="Switch workflows without losing your tasks." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <ToggleButton fx:id="foundationModeButton"
                              accessibleText="Foundation required task workflow"
                              onAction="#showFoundation"
                              selected="true"
                              styleClass="mode-button">
                    <graphic>
                        <VBox spacing="1.0">
                            <Label styleClass="mode-title" text="Foundation" />
                            <Label styleClass="mode-copy" text="Required task workflow" />
                        </VBox>
                    </graphic>
                </ToggleButton>
                <ToggleButton fx:id="advancedModeButton"
                              accessibleText="Advanced complete task workflow"
                              onAction="#showAdvanced"
                              styleClass="mode-button">
                    <graphic>
                        <VBox spacing="1.0">
                            <Label styleClass="mode-title" text="Advanced" />
                            <Label styleClass="mode-copy" text="Complete task workflow" />
                        </VBox>
                    </graphic>
                </ToggleButton>
            </HBox>
            <VBox spacing="5.0">
                <Label fx:id="eyebrowLabel"
                       styleClass="eyebrow-label"
                       text="GROUP ASSIGNMENT · FOUNDATION" />
                <Label fx:id="titleLabel" styleClass="title-label" text="JavaFX Task List" />
                <Label fx:id="subtitleLabel"
                       styleClass="subtitle-label"
                       text="Add tasks, mark work complete, and remove items from one synchronized list." />
            </VBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="12.0">
            <padding>
                <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
            </padding>
            <HBox fx:id="advancedStats" spacing="10.0" styleClass="stats-panel">
                <VBox HBox.hgrow="ALWAYS" spacing="2.0" styleClass="stat-card">
                    <Label styleClass="stat-name" text="TOTAL TASKS" />
                    <Label fx:id="totalCountLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="2.0" styleClass="stat-card">
                    <Label styleClass="stat-name" text="ACTIVE" />
                    <Label fx:id="activeCountLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="2.0" styleClass="stat-card">
                    <Label styleClass="stat-name" text="IN REVIEW" />
                    <Label fx:id="reviewCountLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="2.0" styleClass="stat-card">
                    <Label styleClass="stat-name" text="COMPLETED" />
                    <Label fx:id="completedCountLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="8.0" styleClass="stat-card">
                    <Label fx:id="progressLabel" styleClass="progress-label" text="0% COMPLETE" />
                    <ProgressBar fx:id="progressBar" maxWidth="Infinity" progress="0.0" />
                </VBox>
            </HBox>
            <VBox spacing="8.0" styleClass="input-panel">
                <Label labelFor="$taskField" styleClass="field-label" text="New task" />
                <HBox alignment="BOTTOM_LEFT" spacing="10.0">
                    <TextField fx:id="taskField"
                               HBox.hgrow="ALWAYS"
                               onAction="#handleAddTask"
                               promptText="What needs to be done?" />
                    <HBox fx:id="priorityField" alignment="BOTTOM_LEFT">
                        <VBox spacing="4.0">
                            <Label labelFor="$priorityBox" styleClass="compact-field-label" text="Priority" />
                            <ComboBox fx:id="priorityBox" prefWidth="120.0" />
                        </VBox>
                    </HBox>
                    <Button fx:id="addTaskButton"
                            defaultButton="true"
                            onAction="#handleAddTask"
                            text="Add Task" />
                </HBox>
                <Label fx:id="statusLabel" styleClass="status-label" wrapText="true" />
            </VBox>
            <HBox fx:id="advancedToolbar" alignment="CENTER_LEFT" spacing="8.0">
                <Label minWidth="50.0" styleClass="filter-label" text="SHOW" />
                <ToggleButton fx:id="allFilterButton"
                              onAction="#handleFilterTasks"
                              selected="true"
                              styleClass="filter-button"
                              text="All" />
                <ToggleButton fx:id="activeFilterButton"
                              onAction="#handleFilterTasks"
                              styleClass="filter-button"
                              text="Active" />
                <ToggleButton fx:id="reviewFilterButton"
                              onAction="#handleFilterTasks"
                              styleClass="filter-button"
                              text="In Review" />
                <ToggleButton fx:id="completedFilterButton"
                              onAction="#handleFilterTasks"
                              styleClass="filter-button"
                              text="Completed" />
                <Label styleClass="filter-label" text="PRIORITY" />
                <ComboBox fx:id="priorityFilterBox"
                          accessibleText="Filter tasks by priority"
                          onAction="#handlePriorityFilter"
                          prefWidth="115.0"
                          styleClass="filter-priority-box" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="clearCompletedButton"
                        onAction="#handleClearCompleted"
                        styleClass="clear-button"
                        text="Clear completed" />
            </HBox>
            <ListView fx:id="taskListView"
                      accessibleText="Task list"
                      styleClass="task-list"
                      VBox.vgrow="ALWAYS">
                <placeholder>
                    <VBox alignment="CENTER" spacing="6.0">
                        <Label styleClass="empty-title" text="No tasks in this view" />
                        <Label styleClass="empty-copy" text="Add a task or choose another filter." />
                    </VBox>
                </placeholder>
            </ListView>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" styleClass="footer-panel">
            <padding>
                <Insets bottom="13.0" left="24.0" right="24.0" top="13.0" />
            </padding>
            <Label fx:id="summaryLabel" styleClass="summary-label" text="0 of 0 tasks completed" />
        </HBox>
    </bottom>
</BorderPane>
