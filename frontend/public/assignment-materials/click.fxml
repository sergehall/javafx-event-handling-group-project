<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<VBox fx:controller="sample.JavaFX_EventHandling.ClickController" alignment="CENTER" spacing="5.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
   	  <TextField fx:id="txtInput" />
      <Button text="Click Me" onAction="#onButtonClicked"/>
